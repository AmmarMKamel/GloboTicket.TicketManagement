{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "GloboTicketTicketManagementConnectionString": "Server=localhost\\SQLEXPRESS;Database=GloboTicketTicketManagement;Trusted_Connection=True;TrustServerCertificate=true;"
  },
  "EmailSettings": {
    "FromAddress": "test@example.com",
    "FromName": "GloboTicket Ticket Management",
    "ApiKey": "YOUR_SENDGRID_API_KEY"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": { "expression": "@mt = 'An unhandled exception has occurred while executing the request.'" }
      }
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "ApiUrl": "https://localhost:7211",
  "BlazorUrl": "https://localhost:7212"
}
